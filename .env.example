# ─── IMAP ─────────────────────────────────────────────────────────────────────
IMAP_HOST=imap.gmail.com
IMAP_PORT=993
IMAP_SSL=true
IMAP_USER=user@example.com
IMAP_PASSWORD=app-specific-password
IMAP_FOLDER=INBOX
POLL_INTERVAL=60

# ─── Security ─────────────────────────────────────────────────────────────────
# Comma-separated list of allowed sender addresses (case-insensitive)
ALLOWED_SENDERS=me@example.com,boss@example.com
# Optional: path to additional senders file (one address per line, # = comment)
ALLOWED_SENDERS_FILE=
MAX_ATTACHMENT_MB=20
ALLOWED_EXTENSIONS=pdf,png,jpg,jpeg,docx,doc,xlsx,xls,odt,ods,txt

# ─── Attachment handling ───────────────────────────────────────────────────────
# FIRST = print only the first matching attachment; ALL = print all
PRINT_ATTACHMENTS=FIRST
PRINTED_DIR=/data/printed

# ─── Post-print ───────────────────────────────────────────────────────────────
DELETE_FROM_MAILBOX=true

# ─── Printer (CUPS inside container) ──────────────────────────────────────────
PRINTER_NAME=office
# IPP: ipp://192.168.1.50/ipp/print  |  RAW socket: socket://192.168.1.50:9100
PRINTER_URI=ipp://192.168.1.50/ipp/print
PRINT_DEFAULT_ORIENTATION=P   # P = portrait | L = landscape
PRINT_DEFAULT_SIDES=2         # 1 = one-sided | 2 = duplex
PRINT_DEFAULT_EDGE=l          # s = short-edge | l = long-edge (duplex only)

# ─── Misc ─────────────────────────────────────────────────────────────────────
DB_PATH=/data/state.db
TZ=Europe/Moscow
LOG_LEVEL=INFO
